event PriceUpdate(num price);
event TradeEvent(num price, num volume, string symbol);

agent PriceLogger(num price) on (PriceUpdate) :=
    log(price)
;

agent TradeLogger(num price, num volume, string symbol) on (TradeEvent) :=
    log(price, volume, symbol)
;

