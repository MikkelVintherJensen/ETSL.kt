event MarketSnapshot(num price1, num price2, num price3, num volume, string market, bool verified);

num highPriceThreshold := 90.0;
num adjustmentFee := 5.0;

num function abs(num x) :=
    if x < 0.0 then 0.0 - x else x;

num function average3(num a, num b, num c) :=
    (a + b + c) / 3.0;

bool function isHighPrice(num price, num threshold) :=
    price > threshold;

record<num price, num volume, string market, bool verified> baseTrade :=
    { price := 80.0, volume := 10.0, market := "DK1", verified := true };

list<num> historicalPrices := [75.0, 82.0, 88.0];

num historicalFirst := head(historicalPrices);
num historicalSecond := head(tail(historicalPrices));

agent SnapshotAgent(num price1, num price2, num price3, num volume, string market, bool verified) on (MarketSnapshot) :=
    let list<num> prices := [price1, price2, price3] in
    let num firstPrice := head(prices) in
    let num secondPrice := head(tail(prices)) in
    let num avgPrice := average3(price1, price2, price3) in
    let record<num price, num volume, string market, bool verified> trade :=
        { price := avgPrice, volume := volume, market := market, verified := verified } in
    log(firstPrice, secondPrice, avgPrice);
    call RiskAgent(trade.price, trade.volume, trade.market, trade.verified);
    skip;

agent RiskAgent(num price, num volume, string market, bool verified) on () :=
    let bool highPrice := isHighPrice(price, highPriceThreshold) in
    let num adjustedPrice := price + adjustmentFee in
    let record<num adjustedPrice, string market, bool highPrice, bool verified> riskRecord :=
        { adjustedPrice := adjustedPrice, market := market, highPrice := highPrice, verified := verified } in
    log(adjustedPrice, market, highPrice, verified);

num finalResult := baseTrade.price + historicalFirst + historicalSecond;